<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_order_form_commitment_date" model="ir.ui.view">
            <field name="name">sale.order.form.commitment.date</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <field name="can_edit_commitment_date" invisible="1"/>
                </xpath>

                <xpath expr="//field[@name='commitment_date']" position="attributes">
                    <attribute name="readonly">not can_edit_commitment_date</attribute>
                </xpath>

                <xpath expr="//field[@name='order_line']//field[@name='product_uom_qty']" position="after">
                    <field name="line_commitment_date"
                           string="Fecha Entrega Línea"
                           optional="show"
                           readonly="not parent.can_edit_commitment_date"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>